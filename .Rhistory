mutate(
age_round = round(age_at_test),
group = ifelse(CAH == 1, "CAH", "Female Referents")
) %>%
group_by(group, age_round) %>%
summarise(
mean_value = mean(systolic_mean, na.rm = TRUE),
n_obs = n(),
.groups = "drop"
)
library(ggplot2)
library(plotly)
