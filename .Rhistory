"<br>Mean Systolic BP: ", round(mean_value, 2),
"<br>N observations: ", n_obs
)
)
) +
geom_line(linewidth = 1.2) +
geom_point(size = 2) +
labs(
x = "Age (years)",
y = "Mean Systolic Blood Pressure (mm Hg)",
color = NULL
) +
theme_minimal(base_size = 14)
ggplotly(p_line, tooltip = "text")
