library(haven)
library(ggplot2)
library(plotly)
library(gtsummary)
make_interactive_plot_clean <- function(plot_data, y_label, value_label, plot_title) {
summary_dat <- plot_data %>%
group_by(group) %>%
summarise(
n = n(),
mean_group = mean(mean_value, na.rm = TRUE),
median_group = median(mean_value, na.rm = TRUE),
.groups = "drop"
)
plot_data <- plot_data %>%
mutate(
hover_text = paste0(
"Group: ", group,
"<br>Participant mean: ", round(mean_value, 1),
"<br>Non-missing visits: ", n_visits_nonmissing
)
)
p <- ggplot(plot_data, aes(x = group, y = mean_value, fill = group)) +
geom_boxplot(width = 0.5, alpha = 0.65, outlier.shape = NA) +
geom_jitter(
aes(text = hover_text),
width = 0.12,
alpha = 0.5,
size = 2,
show.legend = FALSE
) +
stat_summary(
fun = mean,
geom = "point",
shape = 23,
size = 3,
fill = "white",
color = "black"
) +
labs(
x = NULL,
y = y_label,
title = plot_title
) +
theme_minimal(base_size = 14) +
theme(
legend.position = "none",
panel.grid.minor = element_blank(),
axis.text.x = element_text(face = "bold", size = 12),
plot.title = element_text(face = "bold")
)
ggplotly(p, tooltip = "text")
}
